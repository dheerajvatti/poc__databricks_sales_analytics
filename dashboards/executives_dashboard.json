{
  "datasets": [
    {
      "name": "ds_ytd_kpi",
      "displayName": "YTD KPI",
      "queryLines": [
        "SELECT `Fiscal Year Label` AS fiscal_year_label, `Fiscal Month` AS fiscal_month, MEASURE(`YTD Revenue`) AS ytd_revenue, MEASURE(`YTD Order Count`) AS ytd_orders, MEASURE(`YTD Average Order Value`) AS ytd_aov FROM workspace.silver_dev.metrics_fiscal_ytd_revenue GROUP BY ALL ORDER BY `Fiscal Year Label` DESC, `Fiscal Month` DESC LIMIT 1"
      ]
    }
  ],
  "pages": [
    {
      "name": "executive_summary",
      "displayName": "Executive Summary",
      "pageType": "PAGE_TYPE_CANVAS",
      "layout": [
        {
          "widget": {
            "name": "title",
            "textbox_spec": "# Pharma Distribution Executive Summary"
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 6,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "subtitle",
            "textbox_spec": "Summary KPIs sourced only from metric views"
          },
          "position": {
            "x": 0,
            "y": 1,
            "width": 6,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "kpi_ytd_revenue",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_ytd_kpi",
                  "fields": [
                    {
                      "name": "ytd_revenue",
                      "expression": "`ytd_revenue`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "ytd_revenue",
                  "displayName": "YTD Revenue",
                  "numberFormatSpec": {
                    "formatType": "CURRENCY",
                    "currencyCode": "USD",
                    "precision": 0
                  }
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Current Fiscal YTD Revenue"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 2,
            "width": 2,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi_ytd_orders",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_ytd_kpi",
                  "fields": [
                    {
                      "name": "ytd_orders",
                      "expression": "`ytd_orders`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "ytd_orders",
                  "displayName": "YTD Orders"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Current Fiscal YTD Orders"
              }
            }
          },
          "position": {
            "x": 2,
            "y": 2,
            "width": 2,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi_ytd_aov",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_ytd_kpi",
                  "fields": [
                    {
                      "name": "ytd_aov",
                      "expression": "`ytd_aov`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "ytd_aov",
                  "displayName": "YTD AOV",
                  "numberFormatSpec": {
                    "formatType": "CURRENCY",
                    "currencyCode": "USD",
                    "precision": 2
                  }
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Current Fiscal YTD AOV"
              }
            }
          },
          "position": {
            "x": 4,
            "y": 2,
            "width": 2,
            "height": 3
          }
        }
      ]
    }
  ]
}
