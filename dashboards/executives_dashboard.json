  "datasets": [
    {
      "name": "monthly_revenue",
      "displayName": "Monthly Revenue",
      "tables": [
        {
          "datasetTable": {
            "tableReference": {
              "table": "fct_sales_order_lines",
              "schema": "silver_dev",
              "catalog": "workspace"
            },
            "isPhysicalTable": true
          },
          "shallowMode": true
        }
      ],
      "definition": {
        "scalarFunctions": [
          {
            "fieldAlias": "month_label",
            "scalarFunctionType": "CAST",
            "input": {
              "column": "order_date"
            },
            "dataType": "date"
          }
        ],
        "customExpression": "SELECT\n  DATE_TRUNC('MONTH', o.order_date)::text AS month_label,\n  SUM(l.line_amount) AS total_revenue,\n  COUNT(DISTINCT l.order_id) AS order_count,\n  ROUND(SUM(l.line_amount) / NULLIF(COUNT(DISTINCT l.order_id), 0), 2) AS avg_order_value,\n  ROUND(SUM(l.confirmed_qty_packs) / NULLIF(SUM(l.ordered_qty_packs), 0), 4) AS fulfillment_rate\nFROM\n  workspace.silver_dev.fct_sales_order_lines l\n  INNER JOIN workspace.silver_dev.fct_sales_orders o ON l.order_id = o.order_id\n  INNER JOIN workspace.silver_dev.dim_time t ON o.date_key = t.date_key\nWHERE\n  YEAR(o.order_date) = 2026\nGROUP BY\n  DATE_TRUNC('MONTH', o.order_date)\nORDER BY\n  DATE_TRUNC('MONTH', o.order_date) DESC"
      }
    }
  ]
}
