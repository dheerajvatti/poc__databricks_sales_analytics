{
  "datasets": [
    {
      "name": "ds_ytd_kpi",
      "displayName": "YTD KPI",
      "queryLines": [
        "SELECT `Fiscal Year Label` AS fiscal_year_label, `Fiscal Month` AS fiscal_month, MEASURE(`YTD Revenue`) AS ytd_revenue, MEASURE(`YTD Order Count`) AS ytd_orders, MEASURE(`YTD Average Order Value`) AS ytd_aov FROM workspace.silver_dev.metrics_fiscal_ytd_revenue GROUP BY ALL ORDER BY `Fiscal Year Label` DESC, `Fiscal Month` DESC LIMIT 1"
      ]
    },
    {
      "name": "ds_daily_revenue",
      "displayName": "Daily Revenue Trend",
      "queryLines": [
        "SELECT `Calendar Date` AS calendar_date, MEASURE(`Revenue`) AS revenue, MEASURE(`Order Count`) AS order_count FROM workspace.silver_dev.metrics_daily_revenue WHERE `Calendar Date` >= date_sub(current_date(), 90) GROUP BY ALL ORDER BY `Calendar Date`"
      ]
    },
    {
      "name": "ds_monthly_metrics",
      "displayName": "Monthly Metrics",
      "queryLines": [
        "SELECT `Month Label` AS month_label, `Fiscal Quarter` AS fiscal_quarter, MEASURE(`Revenue`) AS revenue, MEASURE(`Order Count`) AS order_count, MEASURE(`Average Order Value`) AS avg_order_value, MEASURE(`Fulfillment Rate`) AS fulfillment_rate FROM workspace.silver_dev.metrics_monthly_revenue WHERE `Fiscal Year` >= year(current_date()) - 1 GROUP BY ALL ORDER BY `Month Label`"
      ]
    },
    {
      "name": "ds_returns",
      "displayName": "Returns Summary",
      "queryLines": [
        "SELECT `Year Month` AS year_month, `Return Reason` AS return_reason, MEASURE(`Return Count`) AS return_count, MEASURE(`Return Amount`) AS return_amount FROM workspace.silver_dev.metrics_returns_by_date WHERE `Fiscal Year` >= year(current_date()) - 1 GROUP BY ALL ORDER BY return_count DESC, `Year Month` DESC"
      ]
    }
  ],
  "pages": [
