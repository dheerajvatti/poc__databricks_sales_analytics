{
  "pages": [
    {
      "name": "executive_summary",
      "pageType": "PAGE_TYPE_CANVAS",
      "displayName": "Executive Summary",
      "widgets": [
        {
          "widget": {
            "name": "title_section",
            "textbox_spec": "# Pharma Distribution Analytics Dashboard\n## Real-time Executive Metrics"
          },
          "position": {"x": 0, "y": 0, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "kpi_total_revenue",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "revenue",
                  "fields": [
                    {"name": "total_revenue", "expression": "SUM(amount)"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_revenue",
                  "displayName": "Total Revenue",
                  "numberFormatSpec": {"formatType": "CURRENCY", "currencyCode": "USD", "precision": 0}
                }
              },
              "frame": {"showTitle": true, "title": "Total Revenue (All Time)"}
            }
          },
          "position": {"x": 0, "y": 1, "width": 2, "height": 2}
        },
        {
          "widget": {
            "name": "kpi_total_orders",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "orders",
                  "fields": [
                    {"name": "order_count", "expression": "COUNT(DISTINCT order_id)"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "order_count", "displayName": "Total Orders"}
              },
              "frame": {"showTitle": true, "title": "Total Orders"}
            }
          },
          "position": {"x": 2, "y": 1, "width": 2, "height": 2}
        },
        {
          "widget": {
            "name": "kpi_active_shipments",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "shipments",
                  "fields": [
                    {"name": "shipment_count", "expression": "COUNT(DISTINCT shipment_id)"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "shipment_count", "displayName": "Total Shipments"}
              },
              "frame": {"showTitle": true, "title": "Total Shipments"}
            }
          },
          "position": {"x": 4, "y": 1, "width": 2, "height": 2}
        },
        {
          "widget": {
            "name": "revenue_trend_90d",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "revenue_trend",
                  "fields": [
                    {"name": "order_date", "expression": "`order_date`"},
                    {"name": "daily_revenue", "expression": "SUM(amount)"}
                  ],
                  "disaggregated": true,
                  "filters": [
                    {
                      "expression": "`order_date` >= DATE_SUB(CURRENT_DATE(), 90)"
                    }
                  ],
                  "groupBy": [
                    {
                      "expression": "`order_date`"
                    }
                  ]
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": {
                  "fieldName": "order_date",
                  "scale": {"type": "temporal"},
                  "displayName": "Date"
                },
                "y": {
                  "fieldName": "daily_revenue",
                  "scale": {"type": "quantitative"},
                  "displayName": "Revenue ($)"
                }
              },
              "frame": {"showTitle": true, "title": "Revenue Trend (Last 90 Days)"}
            }
          },
          "position": {"x": 0, "y": 3, "width": 3, "height": 4}
        },
        {
          "widget": {
            "name": "orders_vs_shipments",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "orders_shipments",
                  "fields": [
                    {"name": "order_date", "expression": "DATE_TRUNC('MONTH', `order_date`)"},
                    {"name": "order_count", "expression": "COUNT(DISTINCT order_id)"},
                    {"name": "shipment_count", "expression": "COUNT(DISTINCT shipment_id)"}
                  ],
                  "disaggregated": true,
                  "filters": [
                    {
                      "expression": "`order_date` >= DATE_SUB(CURRENT_DATE(), 180)"
                    }
                  ],
                  "groupBy": [
                    {
                      "expression": "DATE_TRUNC('MONTH', `order_date`)"
                    }
                  ]
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": {
                  "fieldName": "order_date",
                  "scale": {"type": "temporal"},
                  "displayName": "Month"
                },
                "y": {
                  "fieldName": "order_count",
                  "scale": {"type": "quantitative"},
                  "displayName": "Count"
                }
              },
              "frame": {"showTitle": true, "title": "Orders vs Shipments (6 Months)"}
            }
          },
          "position": {"x": 3, "y": 3, "width": 3, "height": 4}
        },
        {
          "widget": {
            "name": "section_metrics",
            "textbox_spec": "## Key Metrics by Category"
          },
          "position": {"x": 0, "y": 7, "width": 6, "height": 0.5}
        },
        {
          "widget": {
            "name": "avg_order_value",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "aov",
                  "fields": [
                    {"name": "avg_value", "expression": "AVG(amount)"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "avg_value",
                  "displayName": "AOV",
                  "numberFormatSpec": {"formatType": "CURRENCY", "currencyCode": "USD", "precision": 2}
                }
              },
              "frame": {"showTitle": true, "title": "Average Order Value"}
            }
          },
          "position": {"x": 0, "y": 7.5, "width": 1.5, "height": 2}
        },
        {
          "widget": {
            "name": "on_hand_inventory",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "inventory",
                  "fields": [
                    {"name": "on_hand_qty", "expression": "CAST(SUM(on_hand_quantity) AS LONG)"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "on_hand_qty", "displayName": "Units"}
              },
              "frame": {"showTitle": true, "title": "On-Hand Inventory"}
            }
          },
          "position": {"x": 1.5, "y": 7.5, "width": 1.5, "height": 2}
        },
        {
          "widget": {
            "name": "pending_shipments",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "pending_ships",
                  "fields": [
                    {"name": "pending_count", "expression": "COUNT(DISTINCT shipment_id)"}
                  ],
                  "disaggregated": false,
                  "filters": [
                    {
                      "expression": "`shipment_status` = 'SHIPPED' OR `shipment_status` = 'IN_TRANSIT'"
                    }
                  ]
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "pending_count", "displayName": "Count"}
              },
              "frame": {"showTitle": true, "title": "In-Transit Shipments"}
            }
          },
          "position": {"x": 3, "y": 7.5, "width": 1.5, "height": 2}
        },
        {
          "widget": {
            "name": "total_returns",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "returns",
                  "fields": [
                    {"name": "return_count", "expression": "COUNT(DISTINCT return_id)"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "return_count", "displayName": "Units"}
              },
              "frame": {"showTitle": true, "title": "Total Returns"}
            }
          },
          "position": {"x": 4.5, "y": 7.5, "width": 1.5, "height": 2}
        }
      ]
    }
  ]
}
